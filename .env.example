# ── Token Discovery Pipeline — Environment Variables ──────────────────────────
# Copy to .env and fill in your values.
# Never commit .env to version control.

# ── Required for AI analysis (L4/L5) ──────────────────────────────────────────
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override model (default: claude-haiku-4-5-20251001 — cheapest)
# Use claude-sonnet-4-6 for better analysis quality at higher cost.
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ── GitHub API (optional, but strongly recommended) ────────────────────────────
# Without this, GitHub rate limit is 60/h (usually enough for small runs).
# Get from: https://github.com/settings/tokens (read-only, public repos only)
GITHUB_TOKEN=ghp_...

# ── Notification channels (at least one recommended) ──────────────────────────
# Discord: Create a Webhook in Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Notion: Create integration at https://www.notion.so/my-integrations
# Share the database page with the integration.
NOTION_API_KEY=secret_...
NOTION_DATABASE_ID=...

# ── Database ───────────────────────────────────────────────────────────────────
# Default: SQLite in project root. Change for PostgreSQL in production.
DATABASE_URL=sqlite:///token_pipeline.db

# ── Pipeline mode ──────────────────────────────────────────────────────────────
# "scheduler" = run APScheduler continuously (default)
# "once"      = run all layers once and exit (useful for testing)
PIPELINE_MODE=scheduler
